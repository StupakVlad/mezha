        "responses": {
          "values": [
            {
              "content": "=You are a lead classifier for a digital agency. Return ONLY a valid JSON object — no markdown, no comments.\n\nSchema:\n{\n  \"summary\": string (1-2 sentences in Ukrainian),\n  \"temperature\": \"hot\" | \"warm\" | \"cold\",\n  \"quality\": \"high\" | \"medium\" | \"low\",\n  \"category\": \"website\" | \"web_app\" | \"integration\" | \"ai\" | \"design\" | \"other\",\n  \"priority\": \"p0\" | \"p1\" | \"p2\" | \"p3\",\n  \"is_spam\": boolean,\n  \"fit_score\": 0-100,\n  \"red_flags\": string[],\n  \"highlights\": string[],\n  \"next_action\": \"call\" | \"email_clarification\" | \"send_proposal\" | \"schedule_meeting\" | \"ignore\"\n}\n\nRules:\n- timeline=\"asap\" → temperature is \"hot\" or \"warm\", never \"cold\".\n- budget=\"discuss\" means wants to discuss, NOT no money. Do not penalize.\n- Re-classify category from message if it conflicts with project_type (e.g. project_type=\"web_app\" but message about Instagram AI bot → category=\"ai\").\n\nLead data:\n{{ JSON.stringify($('Data normalization').item.json) }}"
            }
          ]
        },
        "builtInTools": {},
        "options": {
          "textFormat": {
            "textOptions": {
              "type": "json_object"
            }
          }
        }
