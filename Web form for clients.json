        "jsCode": "// Loop over input items and add a new field called 'myNewField' to the JSON of each one\nconst DICT = {\n  project_type: {\n    website: 'Сайт / Лендинг',\n    web_app: 'Веб-додаток',\n    integration: 'Інтеграція',\n    ai: 'AI-рішення',\n    design: 'Дизайн',\n    other: 'Інше'\n  },\n  category: {\n    website: 'Сайт / Лендинг',\n    web_app: 'Веб-додаток',\n    integration: 'Інтеграція',\n    ai: 'AI-рішення',\n    design: 'Дизайн',\n    other: 'Інше'\n  },\n  budget: {\n    '<2k': 'До 2 000$',\n    '2k-5k': '2-5 тис. $',\n    '5k-10k': '5-10 тис. $',\n    '10k+': '10 тис. $+',\n    discuss: 'Обговорюється'\n  },\n  timeline: {\n    asap: 'Терміново',\n    '1m': 'До 1 місяця',\n    '2-3m': '2-3 місяці',\n    flexible: 'Гнучко'\n  },\n  temperature: {\n    hot: '🔥 Гарячий',\n    warm: '🌤 Теплий',\n    cold: '❄️ Холодний'\n  },\n  quality: {\n    high: 'Висока',\n    medium: 'Середня',\n    low: 'Низька'\n  },\n  next_action: {\n    call: 'Подзвонити',\n    email_clarification: 'Уточнити поштою',\n    send_proposal: 'Надіслати пропозицію',\n    schedule_meeting: 'Призначити зустріч',\n    ignore: 'Ігнорувати'\n  },\n    priority: {\n    p0: '⏱ Зараз',\n    p1: '📅 Сьогодні',\n    p2: '🗓 24 години',\n    p3: '📥 Коли буде час'\n  }\n};\n\nconst data = $input.first().json;\nconst tr = (field, value) => DICT[field]?.[value] ?? value;\n\nreturn [{\n  json: {\n    ...data,\n    project_type: tr('project_type', data.project_type),\n    category:    tr('category', data.category),\n    budget:      tr('budget', data.budget),\n    timeline:    tr('timeline', data.timeline),\n    temperature: tr('temperature', data.temperature),\n    quality:     tr('quality', data.quality),\n    next_action: tr('next_action', data.next_action),\n    is_spam:     data.is_spam ? 'Так' : 'Ні',\n    priority: tr('priority', data.priority),\n    highlights: (data.highlights || []).join('\\n'),\nred_flags:  (data.red_flags  || []).join('\\n')\n  }\n}];"
