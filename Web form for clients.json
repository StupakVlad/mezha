    {
      "parameters": {
        "jsCode": "// Loop over input items and add a new field called 'myNewField' to the JSON of each one\n\nconst d = $input.first().json;\n\nconst trim  = (s) => (s ?? '').toString().trim();\nconst lower = (s) => trim(s).toLowerCase();\n\n// email\nconst email = lower(d.email);\nconst emailDomain = email.split('@')[1] || '';\nconst personalDomains = ['gmail.com','outlook.com'];\n\n// phone\nlet phone = trim(d.phone).replace(/[^\\d+]/g, '');\nif (phone.startsWith('+')) { /* already */ }\nelse if (phone.startsWith('380')) phone = '+' + phone;\nelse if (phone.startsWith('0'))   phone = '+38' + phone;\nelse if (phone.length === 9)      phone = '+380' + phone;\n\n// budget\nconst budgetMap = {\n  '<2k':    { min: 0,     max: 2000  },\n  '2k-5k':  { min: 2000,  max: 5000  },\n  '5k-10k': { min: 5000,  max: 10000 },\n  '10k+':   { min: 10000, max: null  },\n  'discuss':{ min: null,  max: null  }\n};\nconst budget = budgetMap[d.budget] || { min: null, max: null };\n\n// source\nconst sourceCategoryMap = {\n  google:'search', tiktok:'social', linkedin:'social',};\nconst source = lower(d.source);\nconst sourceCategory = sourceCategoryMap[source] || (source ? 'other' : 'unknown');\n\n//timezone\nconst submittedUtc = d.meta_info?.submitted_at || new Date().toISOString();\nconst submittedLocal = new Date(submittedUtc).toLocaleString('uk-UA', {\n  timeZone: 'Europe/Kyiv',\n  year: 'numeric', month: '2-digit', day: '2-digit',\n  hour: '2-digit', minute: '2-digit'\n});\n\n//geo\nconst phoneCountry = phone.startsWith('+380') ? 'UA'\n                   : phone.startsWith('+48')  ? 'PL'\n                   : null;\nconst ipCountry = d.meta_info?.country || null;\n\nreturn [{\n  json: {\n    // contact\n    name: trim(d.name),\n    company: trim(d.company),\n    email,\n    email_domain: emailDomain,\n    is_business_email: !!emailDomain && !personalDomains.includes(emailDomain),\n    phone,\n    phone_country: phoneCountry,\n\n    // project signals\n    project_type: trim(d.project_type),\n    budget_raw: d.budget || '',\n    budget_min: budget.min,\n    budget_max: budget.max,\n    budget_known: !!d.budget && d.budget !== 'discuss',\n    timeline: d.timeline || '',\n    is_urgent: ['asap','1m'].includes(d.timeline),\n\n    // attribution\n    source,\n    source_category: sourceCategory,\n\n    // message\n    message: d.message ?? '',\n\n    // meta\n    ip: d.meta_info?.client_ip || '',\n    ip_country: ipCountry,\n    country_consistent: phoneCountry && ipCountry ? phoneCountry === ipCountry : null,\n    submitted_at_utc: submittedUtc,\n    submitted_at_local: submittedLocal,\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
